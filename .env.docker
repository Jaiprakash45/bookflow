PORT=3000

# postgres → service name in docker-compose
DATABASE_URL=postgresql://postgres:secret@postgres:5432/bookflow

# redis → service name in docker-compose
REDIS_HOST=redis
REDIS_PORT=6379

# rabbitmq → service name in docker-compose
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672

JWT_SECRET=thisisaverylongsecretkeymakeitlonger
JWT_EXPIRY=15m

RESERVATION_TTL=600